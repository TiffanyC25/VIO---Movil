<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Conductores"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A0800"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecciona un conductor para ver su historial"
            android:textSize="14sp"
            android:textColor="#B0978E"
            android:layout_marginBottom="12dp"/>

        <!-- Buscador -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etBuscarConductor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:hint="Buscar por nombre o correo..."
                android:textColorHint="#B0978E"
                android:textColor="#1A0800"
                android:textSize="14sp"
                android:paddingStart="44dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:inputType="text"/>

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="🔍"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="12dp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Contador -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvContadorConductores"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CONDUCTORES REGISTRADOS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#B0978E"
            android:letterSpacing="0.08"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarConductores"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="#E05A1E"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvSinConductores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay conductores registrados"
        android:textSize="15sp"
        android:textColor="#B0978E"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerConductores"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"/>

</LinearLayout>