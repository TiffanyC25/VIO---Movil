<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:orientation="vertical">
    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="12dp"
        android:paddingEnd="20dp"
        android:paddingStart="20dp"
        android:paddingTop="16dp">
        <TextView
            android:id="@+id/tvTituloRutasRecorrido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="4dp"
            android:text="Iniciar Recorrido"
            android:textColor="#1A0800"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvSubtituloRutasRecorrido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Selecciona la ruta que vas a operar"
            android:textColor="#B0978E"
            android:textSize="14sp"/>
        <!-- Barra de búsqueda -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="Buscar ruta..."
                android:paddingEnd="14dp"
                android:paddingStart="44dp"
                android:textColor="#1A0800"
                android:textColorHint="#B0978E"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:text="🔍"
                android:textSize="14sp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Contador de rutas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp"
        android:paddingEnd="20dp"
        android:paddingStart="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.08"
            android:text="RUTAS DISPONIBLES"
            android:textColor="#B0978E"
            android:textSize="11sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvSinRutasRecorrido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="No hay rutas disponibles"
            android:textColor="#B0978E"
            android:textSize="14sp"
            android:visibility="gone"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarRutasRecorrido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:indeterminateTint="#E05A1E"
        android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRutasRecorrido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        android:paddingEnd="20dp"
        android:paddingStart="20dp"/>
</LinearLayout>
