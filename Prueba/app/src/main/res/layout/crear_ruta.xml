<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp"
        android:paddingEnd="20dp"
        android:paddingStart="20dp"
        android:paddingTop="16dp">
        <TextView
            android:id="@+id/tvTituloCrearRuta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Crear Ruta"
            android:textColor="#1A0800"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Define los parámetros de tu nueva ruta de transporte."
            android:textColor="#B0978E"
            android:textSize="14sp"/>
        <!-- ═══ Tarjeta: Información básica ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_icon_orange"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="16sp"/>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Información de la Ruta"
                    android:textColor="#1A0800"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#F0E0D6"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.08"
                android:text="NOMBRE DE LA RUTA"
                android:textColor="#7C6860"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/etNombreRuta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="Ej: Ruta Norte — Chía Centro"
                android:inputType="textCapWords"
                android:paddingEnd="14dp"
                android:paddingStart="14dp"
                android:textColor="#1A0800"
                android:textColorHint="#B0978E"
                android:textSize="15sp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.08"
                android:text="DESCRIPCIÓN"
                android:textColor="#7C6860"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/etDescripcionRuta"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="@drawable/input_background"
                android:gravity="top|start"
                android:hint="Describe brevemente el propósito de esta ruta..."
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="#1A0800"
                android:textColorHint="#B0978E"
                android:textSize="15sp"/>
        </LinearLayout>
        <!-- ═══ Tarjeta: Radio de detección ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_icon_amber"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡"
                        android:textSize="16sp"/>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Radio de Detección"
                    android:textColor="#1A0800"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#F0E0D6"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="-0.04"
                        android:text="50"
                        android:textColor="#E05A1E"
                        android:textSize="42sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-4dp"
                        android:text="metros"
                        android:textColor="#B0978E"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_chip_normal"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○"
                        android:textColor="#F0E0D6"
                        android:textSize="28sp"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.08"
                android:text="RADIO (metros)"
                android:textColor="#7C6860"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <EditText
                android:id="@+id/etRadioDeteccion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:hint="Ej: 50"
                android:inputType="numberDecimal"
                android:paddingEnd="14dp"
                android:paddingStart="14dp"
                android:textColor="#1A0800"
                android:textColorHint="#B0978E"
                android:textSize="15sp"/>
            <!-- Info tip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_warning"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ  "
                    android:textColor="#C07000"
                    android:textSize="13sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="El sistema marcará un waypoint como visitado cuando el conductor esté dentro de este radio."
                    android:textColor="#7C6860"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/btn_outline_orange"
                android:stateListAnimator="@null"
                android:text="Cancelar"
                android:textColor="#E05A1E"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnGuardarRuta"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="2"
                android:background="@drawable/btn_primary"
                android:stateListAnimator="@null"
                android:text="Guardar Ruta →"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tvEstadoRuta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text=""
            android:textColor="#30D158"
            android:textSize="14sp"/>
    </LinearLayout>

</ScrollView>
