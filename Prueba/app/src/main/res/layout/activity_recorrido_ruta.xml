<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- ═══ MAPA placeholder ═══ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:background="@drawable/bg_map_placeholder">
            <!-- Puntos decorativos del mapa -->
            <!-- Pin completado -->
            <LinearLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="55dp"
                android:layout_marginTop="170dp"
                android:background="@drawable/bg_icon_green"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="#30D158"
                    android:textSize="12sp"/>
            </LinearLayout>
            <!-- Pin siguiente (con pulso) -->
            <LinearLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="100dp"
                android:background="@drawable/bg_icon_orange"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧭"
                    android:textSize="16sp"/>
            </LinearLayout>
            <!-- Pin pendiente 1 -->
            <LinearLayout
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="80dp"
                android:layout_marginTop="60dp"
                android:background="@drawable/card_background"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•"
                    android:textColor="#D0C0B8"
                    android:textSize="14sp"/>
            </LinearLayout>
            <!-- Velocidad badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:letterSpacing="-0.03"
                    android:text="42"
                    android:textColor="#1A0800"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="km/h"
                    android:textColor="#B0978E"
                    android:textSize="10sp"/>
            </LinearLayout>
            <!-- Botón cerrar -->
            <LinearLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_margin="12dp"
                android:background="@drawable/card_background"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#7C6860"
                    android:textSize="14sp"/>
            </LinearLayout>
            <!-- Label "Ruta Norte Express" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_tab_container"
                android:letterSpacing="0.08"
                android:paddingBottom="6dp"
                android:paddingEnd="12dp"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:text="Visualización de Ruta"
                android:textColor="#B0978E"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </RelativeLayout>
        <!-- ═══ CONTENIDO INFERIOR ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingEnd="20dp"
            android:paddingStart="20dp"
            android:paddingTop="16dp">
            <!-- Tarjeta de estado del recorrido -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="18dp">
                <!-- Nombre ruta + badge estado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvTituloRecorrido"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recorrido Activo"
                        android:textColor="#1A0800"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvEstadoRecorrido"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_warning"
                        android:paddingBottom="4dp"
                        android:paddingEnd="10dp"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:text="En curso"
                        android:textColor="#E05A1E"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <!-- Nombre de la ruta -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ruta"
                        android:textColor="#B0978E"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvRutaRecorrido"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruta Norte Express"
                        android:textColor="#1A0800"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <!-- Progreso con barra -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Progreso"
                        android:textColor="#B0978E"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvProgresoRecorrido"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 / 4 puntos"
                        android:textColor="#E05A1E"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginBottom="12dp"
                    android:max="100"
                    android:progress="25"
                    android:progressDrawable="@drawable/progress_track"
                    style="?android:attr/progressBarStyleHorizontal"/>
                <!-- Siguiente punto -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Siguiente punto"
                        android:textColor="#B0978E"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvPuntoSiguienteRecorrido"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tienda Centro"
                        android:textColor="#007AFF"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <!-- Inicio -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hora de inicio"
                        android:textColor="#B0978E"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvTiempoInicioRecorrido"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#1A0800"
                        android:textSize="13sp"/>
                </LinearLayout>
                <!-- GPS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="GPS"
                        android:textColor="#B0978E"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvUbicacionActualRecorrido"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#B0978E"
                        android:textSize="11sp"/>
                </LinearLayout>
                <!-- Oculto (para compatibilidad) -->
                <TextView
                    android:id="@+id/tvCantidadPuntosRecorrido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>
            </LinearLayout>
            <!-- Botones -->
            <Button
                android:id="@+id/btnIniciarRecorrido"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/btn_success"
                android:padding="10dp"
                android:stateListAnimator="@null"
                android:text="▶  Iniciar Recorrido"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnFinalizarManualRecorrido"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                android:alpha="0.45"
                android:background="@drawable/btn_danger"
                android:enabled="false"
                android:padding="10dp"
                android:stateListAnimator="@null"
                android:text="Finalizar manualmente"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <!-- Sección waypoints -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvTituloPuntosRecorrido"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.08"
                    android:text="SEGUIMIENTO DE PUNTOS"
                    android:textColor="#B0978E"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPuntosSeguimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </LinearLayout>

</ScrollView>
