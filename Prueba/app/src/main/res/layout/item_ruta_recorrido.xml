<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_background"
    android:orientation="vertical">
    <!-- Barra de acento superior -->
    <View
        android:id="@+id/viewStrip"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:background="@drawable/strip_orange"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <!-- Nombre + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvNombreRutaRecorridoItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ruta Norte Express"
                android:textColor="#1A0800"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvBadgeEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_success"
                android:paddingBottom="4dp"
                android:paddingEnd="10dp"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:text="Lista"
                android:textColor="#1D9B3C"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tvDescripcionRutaRecorridoItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Descripción de la ruta"
            android:textColor="#B0978E"
            android:textSize="13sp"/>
        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_sync_banner"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="10dp"
            android:paddingEnd="12dp"
            android:paddingStart="12dp"
            android:paddingTop="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 "
                android:textSize="13sp"/>
            <TextView
                android:id="@+id/tvRadioRutaRecorridoItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Radio: 50 m"
                android:textColor="#7C6860"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <View
                android:layout_width="1dp"
                android:layout_height="14dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:background="#C6F6D5"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧭 "
                android:textSize="13sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="38 km"
                android:textColor="#7C6860"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <Button
            android:id="@+id/btnIniciarRecorridoRuta"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_success"
            android:padding="10dp"
            android:stateListAnimator="@null"
            android:text="▶  Iniciar Ruta"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
