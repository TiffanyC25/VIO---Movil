<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:orientation="vertical">

    <!-- Banner de perfil del conductor -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/gradient_orange_topbar">

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/circle_deco_light"
            android:alpha="0.10"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="-30dp"
            android:layout_marginEnd="-30dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_centerVertical="true"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Avatar -->
            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/circle_deco_light"
                android:backgroundTint="#FFD0A8"
                android:gravity="center"
                android:layout_marginEnd="16dp">

                <TextView
                    android:id="@+id/tvInicialesDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="?"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Datos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre Conductor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvEmailDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="correo@ejemplo.com"
                    android:textSize="13sp"
                    android:textColor="#E6FFFFFF"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tvTelefonoDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#CCffffff"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <!-- Stats strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/gradient_orange_topbar"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvStatRecorridos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recorridos"
                android:textSize="11sp"
                android:textColor="#CCffffff"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="#44FFFFFF"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvStatCompletados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completados"
                android:textSize="11sp"
                android:textColor="#CCffffff"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="#44FFFFFF"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvStatTiempoTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiempo total"
                android:textSize="11sp"
                android:textColor="#CCffffff"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Etiqueta sección -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HISTORIAL DE RECORRIDOS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#B0978E"
            android:letterSpacing="0.08"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarHistorialConductor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="#E05A1E"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvSinRecorridos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Este conductor no tiene recorridos registrados"
        android:textSize="14sp"
        android:textColor="#B0978E"
        android:gravity="center"
        android:visibility="gone"
        android:paddingTop="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHistorialConductor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"/>

</LinearLayout>