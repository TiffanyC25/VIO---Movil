<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:map="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- ═══ MAPA (ocupa ~52% de pantalla) ═══ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/bg_map_placeholder">
            <!-- Fragmento real de mapa -->
            <fragment
                android:id="@+id/mapConfigurarPuntos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                map:uiCompass="false"
                map:uiZoomControls="false"/>
            <!-- Control: tipo de mapa -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_margin="10dp"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/card_background"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="10dp"
                    android:paddingStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗺  Vista Completa"
                        android:textColor="#1A0800"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <!-- Zoom +/- -->
                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_background"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="#1A0800"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0E0D6"/>
                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="−"
                        android:textColor="#1A0800"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Hint tap largo -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:layout_margin="10dp"
                android:background="#88000000"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="10dp"
                android:paddingStart="10dp">
                <TextView
                    android:id="@+id/tvInstruccionMapa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap largo para agregar punto"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </RelativeLayout>
        <!-- ═══ PANEL INFERIOR ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"
            android:paddingEnd="20dp"
            android:paddingStart="20dp"
            android:paddingTop="14dp">
            <!-- Info de ruta activa -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvTituloConfigurarPuntos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Configurar puntos"
                        android:textColor="#1A0800"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvNombreRutaConfigurar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Ruta: —"
                        android:textColor="#E05A1E"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnRecargarPuntos"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:background="@drawable/btn_outline_orange"
                    android:paddingEnd="14dp"
                    android:paddingStart="14dp"
                    android:stateListAnimator="@null"
                    android:text="↻  Recargar"
                    android:textColor="#E05A1E"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <!-- Header waypoints -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.08"
                    android:text="WAYPOINTS"
                    android:textColor="#B0978E"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_warning"
                    android:paddingBottom="3dp"
                    android:paddingEnd="8dp"
                    android:paddingStart="8dp"
                    android:paddingTop="3dp"
                    android:text="4 puntos"
                    android:textColor="#E05A1E"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPuntosRuta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
