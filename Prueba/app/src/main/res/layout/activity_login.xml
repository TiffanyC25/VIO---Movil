<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F3"
    android:orientation="vertical">
    <!-- ═══ HERO HEADER con gradiente naranja ═══ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/gradient_orange_topbar">
        <!-- Círculos decorativos -->
        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="-45dp"
            android:layout_marginTop="-45dp"
            android:alpha="0.15"
            android:background="@drawable/circle_deco_light"/>
        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_marginBottom="-30dp"
            android:layout_marginStart="-30dp"
            android:alpha="0.10"
            android:background="@drawable/circle_deco_light"/>
        <!-- Logo + texto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="28dp"
            android:layout_marginStart="28dp"
            android:orientation="vertical">
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/logo"
                android:scaleType="centerCrop"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="-0.02"
                android:text="VIØ"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Gestión de rutas intermunicipales"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- ═══ TAB SELECTOR (superpuesto al header) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-24dp"
        android:orientation="vertical"
        android:paddingEnd="20dp"
        android:paddingStart="20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_tab_container"
            android:elevation="6dp"
            android:orientation="horizontal"
            android:padding="4dp">
            <Button
                android:id="@+id/tabLogin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:stateListAnimator="@null"
                android:text="Iniciar Sesión"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/tabSignup"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:padding="10dp"
                android:stateListAnimator="@null"
                android:text="Registrarse"
                android:textColor="#B0978E"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ FORMULARIO ═══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp"
            android:paddingEnd="20dp"
            android:paddingStart="20dp"
            android:paddingTop="20dp">
            <!-- Campo email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.08"
                android:text="CORREO ELECTRÓNICO"
                android:textColor="#7C6860"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_background"
                    android:gravity="center_vertical"
                    android:hint="correo@empresa.com"
                    android:inputType="textEmailAddress"
                    android:paddingEnd="16dp"
                    android:paddingStart="48dp"
                    android:textColor="#1A0800"
                    android:textColorHint="#B0978E"
                    android:textSize="15sp"/>
                <!-- Ícono email -->
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:gravity="center"
                    android:text="✉"
                    android:textColor="#B0978E"
                    android:textSize="16sp"/>
            </FrameLayout>
            <!-- Campo contraseña -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.08"
                android:text="CONTRASEÑA"
                android:textColor="#7C6860"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <EditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_background"
                    android:gravity="center_vertical"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:paddingEnd="16dp"
                    android:paddingStart="48dp"
                    android:textColor="#1A0800"
                    android:textColorHint="#B0978E"
                    android:textSize="15sp"/>
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:gravity="center"
                    android:text="🔒"
                    android:textSize="14sp"/>
            </FrameLayout>
            <!-- ═══ BOTONES ═══ -->
            <LinearLayout
                android:id="@+id/linearBotones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/login"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="2"
                    android:background="@drawable/btn_primary"
                    android:padding="10dp"
                    android:stateListAnimator="@null"
                    android:text="Iniciar Sesión →"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <!-- Separador "o" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#F0E0D6"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  o continúa con  "
                    android:textColor="#B0978E"
                    android:textSize="12sp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#F0E0D6"/>
            </LinearLayout>
            <!-- Botones sociales -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_container"
                    android:padding="10dp"
                    android:stateListAnimator="@null"
                    android:text="Google"
                    android:textColor="#1A0800"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="Secretaría de Movilidad — Municipio de Chía"
                android:textColor="#B0978E"
                android:textSize="12sp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
