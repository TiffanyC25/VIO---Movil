<resources
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base claro — Secretaría de Movilidad Chía -->
    <style
        name="Base.Theme.Prueba"
        parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Colores primarios -->
        <item
            name="colorPrimary">
                @color/orange_primary
        </item>
        <item
            name="colorPrimaryDark">
                @color/orange_primary_dark
        </item>
        <item
            name="colorPrimaryVariant">
                @color/orange_primary_dark
        </item>
        <item
            name="colorOnPrimary">
                @color/color_on_primary
        </item>
        <!-- Acento / secundario -->
        <item
            name="colorSecondary">
                @color/orange_secondary
        </item>
        <item
            name="colorSecondaryVariant">
                @color/orange_secondary
        </item>
        <item
            name="colorOnSecondary">
                @color/color_on_primary
        </item>
        <!-- Fondos y superficies -->
        <item
            name="android:colorBackground">
                @color/color_background
        </item>
        <item
            name="colorSurface">
                @color/color_surface
        </item>
        <item
            name="colorOnSurface">
                @color/color_text_primary
        </item>
        <item
            name="colorSurfaceVariant">
                @color/color_surface_variant
        </item>
        <!-- Error -->
        <item
            name="colorError">
                @color/error
        </item>
        <item
            name="colorOnError">
                @color/white
        </item>
        <!-- Barra de estado -->
        <item
            name="android:statusBarColor">
                @color/color_status_bar
        </item>
        <item
            tools:targetApi="m"
            name="android:windowLightStatusBar">
                false
        </item>
        <!-- Barra de navegación -->
        <item
            name="android:navigationBarColor">
                @color/color_surface
        </item>
        <!-- Tipografía — habilitar Inter/Poppins si está en fonts/ -->
        <!-- <item name="fontFamily">@font/inter</item> -->
        <!-- Shapes redondeadas -->
        <item
            name="shapeAppearanceSmallComponent">
                @style/ShapeSmall
        </item>
        <item
            name="shapeAppearanceMediumComponent">
                @style/ShapeMedium
        </item>
        <item
            name="shapeAppearanceLargeComponent">
                @style/ShapeLarge
        </item>
        <!-- Botones con el color primario -->
        <item
            name="materialButtonStyle">
                @style/Widget.App.Button
        </item>
        <!-- EditText con estilo Outlined -->
        <item
            name="textInputStyle">
                @style/Widget.App.TextInputLayout
        </item>
    </style>

    <style
        name="Theme.Prueba"
        parent="Base.Theme.Prueba"/>
    <!-- =============================================
    SHAPES
    ============================================= -->
    <style
        name="ShapeSmall"
        parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item
            name="cornerSize">
                8dp
        </item>
    </style>

    <style
        name="ShapeMedium"
        parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item
            name="cornerSize">
                12dp
        </item>
    </style>

    <style
        name="ShapeLarge"
        parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item
            name="cornerSize">
                16dp
        </item>
    </style>

    <!-- =============================================
    BOTONES
    ============================================= -->
    <style
        name="Widget.App.Button"
        parent="Widget.MaterialComponents.Button">
        <item
            name="backgroundTint">
                @color/orange_primary
        </item>
        <item
            name="android:textColor">
                @color/white
        </item>
        <item
            name="cornerRadius">
                8dp
        </item>
        <item
            name="android:paddingTop">
                14dp
        </item>
        <item
            name="android:paddingBottom">
                14dp
        </item>
        <item
            name="android:textSize">
                15sp
        </item>
        <item
            name="android:textStyle">
                bold
        </item>
        <item
            name="android:letterSpacing">
                0.04
        </item>
    </style>

    <style
        name="Widget.App.Button.Outlined"
        parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item
            name="strokeColor">
                @color/orange_primary
        </item>
        <item
            name="android:textColor">
                @color/orange_primary
        </item>
        <item
            name="cornerRadius">
                8dp
        </item>
        <item
            name="android:paddingTop">
                14dp
        </item>
        <item
            name="android:paddingBottom">
                14dp
        </item>
    </style>

    <style
        name="Widget.App.Button.Danger"
        parent="Widget.MaterialComponents.Button">
        <item
            name="backgroundTint">
                @color/error
        </item>
        <item
            name="android:textColor">
                @color/white
        </item>
        <item
            name="cornerRadius">
                8dp
        </item>
    </style>

    <!-- =============================================
    TEXT INPUT
    ============================================= -->
    <style
        name="Widget.App.TextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item
            name="boxStrokeColor">
                @color/color_input_stroke
        </item>
        <item
            name="boxStrokeWidth">
                1dp
        </item>
        <item
            name="boxBackgroundColor">
                @color/color_surface
        </item>
        <item
            name="hintTextColor">
                @color/color_text_secondary
        </item>
        <item
            name="android:textColorHint">
                @color/color_hint
        </item>
        <item
            name="shapeAppearance">
                @style/ShapeSmall
        </item>
    </style>

    <!-- =============================================
    TOOLBAR / APP BAR
    ============================================= -->
    <style
        name="Widget.App.Toolbar"
        parent="Widget.MaterialComponents.Toolbar.Primary">
        <item
            name="android:background">
                @color/orange_primary
        </item>
        <item
            name="titleTextColor">
                @color/white
        </item>
        <item
            name="subtitleTextColor">
                @color/orange_primary_light
        </item>
    </style>

    <!-- =============================================
    TARJETAS
    ============================================= -->
    <style
        name="Widget.App.Card"
        parent="Widget.MaterialComponents.CardView">
        <item
            name="cardBackgroundColor">
                @color/color_surface
        </item>
        <item
            name="cardCornerRadius">
                12dp
        </item>
        <item
            name="cardElevation">
                2dp
        </item>
        <item
            name="strokeColor">
                @color/color_divider
        </item>
        <item
            name="strokeWidth">
                1dp
        </item>
    </style>

    <!-- =============================================
    BADGES DE ESTADO (pill shape)
    ============================================= -->
    <style
        name="Widget.App.Badge"
        parent="@android:style/Widget.TextView">
        <item
            name="android:paddingStart">
                10dp
        </item>
        <item
            name="android:paddingEnd">
                10dp
        </item>
        <item
            name="android:paddingTop">
                4dp
        </item>
        <item
            name="android:paddingBottom">
                4dp
        </item>
        <item
            name="android:textSize">
                12sp
        </item>
        <item
            name="android:textStyle">
                bold
        </item>
    </style>

</resources>
