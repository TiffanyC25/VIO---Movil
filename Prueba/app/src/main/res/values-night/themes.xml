<resources
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema oscuro — Secretaría de Movilidad Chía -->
    <style
        name="Base.Theme.Prueba"
        parent="Theme.MaterialComponents.NoActionBar">
        <!-- Colores primarios (versión noche, más brillante) -->
        <item
            name="colorPrimary">
                @color/orange_primary_night
        </item>
        <item
            name="colorPrimaryDark">
                @color/dark_background
        </item>
        <item
            name="colorPrimaryVariant">
                @color/orange_primary
        </item>
        <item
            name="colorOnPrimary">
                @color/white
        </item>
        <!-- Secundario -->
        <item
            name="colorSecondary">
                @color/orange_secondary
        </item>
        <item
            name="colorSecondaryVariant">
                @color/orange_secondary
        </item>
        <item
            name="colorOnSecondary">
                @color/white
        </item>
        <!-- Fondos y superficies oscuros -->
        <item
            name="android:colorBackground">
                @color/dark_background
        </item>
        <item
            name="colorSurface">
                @color/dark_surface
        </item>
        <item
            name="colorOnSurface">
                @color/dark_text_primary
        </item>
        <item
            name="colorSurfaceVariant">
                @color/dark_surface_variant
        </item>
        <!-- Error -->
        <item
            name="colorError">
                @color/error
        </item>
        <item
            name="colorOnError">
                @color/white
        </item>
        <!-- Barra de estado oscura -->
        <item
            name="android:statusBarColor">
                @color/dark_status_bar
        </item>
        <item
            tools:targetApi="m"
            name="android:windowLightStatusBar">
                false
        </item>
        <item
            name="android:navigationBarColor">
                @color/dark_surface
        </item>
        <!-- Shapes -->
        <item
            name="shapeAppearanceSmallComponent">
                @style/ShapeSmall
        </item>
        <item
            name="shapeAppearanceMediumComponent">
                @style/ShapeMedium
        </item>
        <item
            name="shapeAppearanceLargeComponent">
                @style/ShapeLarge
        </item>
        <!-- Botón oscuro -->
        <item
            name="materialButtonStyle">
                @style/Widget.App.Button.Night
        </item>
        <item
            name="textInputStyle">
                @style/Widget.App.TextInputLayout.Night
        </item>
    </style>

    <!-- Botón en modo oscuro -->
    <style
        name="Widget.App.Button.Night"
        parent="Widget.MaterialComponents.Button">
        <item
            name="backgroundTint">
                @color/orange_primary_night
        </item>
        <item
            name="android:textColor">
                @color/white
        </item>
        <item
            name="cornerRadius">
                8dp
        </item>
        <item
            name="android:paddingTop">
                14dp
        </item>
        <item
            name="android:paddingBottom">
                14dp
        </item>
        <item
            name="android:textSize">
                15sp
        </item>
        <item
            name="android:textStyle">
                bold
        </item>
    </style>

    <!-- Input oscuro -->
    <style
        name="Widget.App.TextInputLayout.Night"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item
            name="boxStrokeColor">
                @color/dark_input_stroke
        </item>
        <item
            name="boxBackgroundColor">
                @color/dark_surface
        </item>
        <item
            name="hintTextColor">
                @color/dark_text_secondary
        </item>
        <item
            name="android:textColorHint">
                @color/dark_hint
        </item>
        <item
            name="shapeAppearance">
                @style/ShapeSmall
        </item>
    </style>

</resources>
